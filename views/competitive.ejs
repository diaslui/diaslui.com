<!DOCTYPE html>
<html lang="en" class="text-base">
  <%- include('partials/head', { title: title, description: description }) %>
       <script src="/assets/scripts/global.js"></script>

  <body
    class="flex h-screen flex-col bg-zinc-50 text-zinc-950 dark:bg-zinc-900 dark:text-zinc-50"
  >
    <%- include('partials/header') %>
    <main class="flex-1">
      <div class="container mx-auto mt-12 max-w-4xl px-4">
        <div class="mb-12 border-b border-zinc-200 pb-8 dark:border-zinc-800">
          <h1 class="mb-4 text-5xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-6xl">
            Competitive <span class="text-amber-600 dark:text-amber-500">Programming</span>
          </h1>
          <p class="mt-4 text-xl leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-2xl">
            Welcome to my personal library. A curated collection of solved problems and raw algorithm implementations.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2"> 
          <a href="/problems" class="group relative flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:-translate-y-1 dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:bg-zinc-800/80">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-100 text-amber-600 dark:bg-amber-500/20 dark:text-amber-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h2 class="mb-3 text-2xl font-bold text-zinc-900 dark:text-zinc-50 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">Solved Problems</h2>
            <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
              Explore my collection of solved problems from Codeforces and other judges, complete with C++ solutions.
            </p>
            <div class="mt-auto pt-6 flex items-center text-sm font-medium text-amber-600 dark:text-amber-400">
              <span>View solutions</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </a>
          
          <div class="group relative flex flex-col rounded-2xl border border-zinc-200 bg-white p-8 opacity-60 shadow-sm transition-all dark:border-zinc-800 dark:bg-zinc-900/50">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600 dark:bg-green-500/20 dark:text-green-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
            </div>
            <h2 class="mb-3 text-2xl font-bold text-zinc-900 dark:text-zinc-50">Algorithms</h2>
            <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
              Pure C++ algorithm implementations and data structures.
            </p>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
