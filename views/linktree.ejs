        </svg>
      </a>
      <a class="social-linkedin social-icon p-3 sm:p-4 rounded-full bg-white dark:bg-subgdark shadow-lg hover:shadow-xl border border-slate-200 dark:border-slate-800 transition-transform hover:scale-110 hover:-translate-y-0.5"
        aria-label="LinkedIn">
