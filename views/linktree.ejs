<!DOCTYPE html>
<html lang="en">

<head>
  <script>
    const theme = localStorage.getItem("theme") || "dark";
    const isDark = theme === "dark";

    if (isDark) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  </script>
  <%-include("./partials/head")-%>
    <title>
      <%= title %> | Pedro Luis D.
    </title>
    <meta name="description" content="<%= description %>">


    <script src="/assets/scripts/global.js"></script>

    <style>
      .ambient-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
      }

      .ambient-shape {
        position: absolute;
        border-radius: 9999px;
        filter: blur(40px);
        opacity: .35;
        will-change: transform;
      }

      .dark .ambient-shape { opacity: .22; }

      .ambient-1 {
        width: 280px; height: 280px; left: -60px; top: 8%;
        background: radial-gradient(circle, #FF7E00, transparent 70%);
        animation: drift1 22s ease-in-out infinite;
      }
      .ambient-2 {
        width: 220px; height: 220px; right: -40px; top: 28%;
        background: radial-gradient(circle, #0A66C2, transparent 70%);
        animation: drift2 26s ease-in-out infinite;
      }
      .ambient-3 {
        width: 260px; height: 260px; left: 10%; bottom: 6%;
        background: radial-gradient(circle, #E1306C, transparent 70%);
        animation: drift3 30s ease-in-out infinite;
      }
      .ambient-4 {
        width: 180px; height: 180px; right: 12%; bottom: 18%;
        background: radial-gradient(circle, #34D399, transparent 70%);
        animation: drift1 18s ease-in-out infinite reverse;
      }
      .ambient-5 {
        width: 200px; height: 200px; left: 45%; top: -40px;
        background: radial-gradient(circle, #FFC900, transparent 70%);
        animation: drift2 24s ease-in-out infinite reverse;
      }

      @keyframes drift1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(40px, 60px) scale(1.15); }
      }
      @keyframes drift2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-50px, 40px) scale(0.9); }
      }
      @keyframes drift3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(30px, -50px) scale(1.1); }
      }

      .ambient-particle {
        position: absolute;
        opacity: 0;
        animation: floatUpFade linear infinite;
      }

      @keyframes floatUpFade {
        0% { transform: translateY(0) rotate(0deg); opacity: 0; }
        10% { opacity: .5; }
        90% { opacity: .4; }
        100% { transform: translateY(-110vh) rotate(180deg); opacity: 0; }
      }

      .dark .ambient-particle { opacity: 0; }

      @media (prefers-reduced-motion: reduce) {
        .ambient-shape, .ambient-particle { animation: none !important; }
      }

      .intro-avatar {
        opacity: 0;
        transform: scale(.4) translateY(10px);
        animation: introPop .7s cubic-bezier(.34,1.56,.64,1) .1s forwards;
      }
      .intro-title {
        opacity: 0;
        filter: blur(6px);
        transform: translateY(14px);
        animation: introBlurUp .7s cubic-bezier(.16,1,.3,1) .35s forwards;
      }
      .intro-subtitle {
        opacity: 0;
        transform: translateY(10px);
        animation: introUp .6s cubic-bezier(.16,1,.3,1) .5s forwards;
      }
      .intro-socials {
        opacity: 0;
        transform: translateY(10px);
        animation: introUp .6s cubic-bezier(.16,1,.3,1) .62s forwards;
      }
      .intro-card {
        opacity: 0;
        transform: translateY(26px) scale(.96);
        animation: introUp .65s cubic-bezier(.16,1,.3,1) forwards;
      }

      @keyframes introPop {
        to { opacity: 1; transform: scale(1) translateY(0); }
      }
      @keyframes introBlurUp {
        to { opacity: 1; filter: blur(0); transform: translateY(0); }
      }
      @keyframes introUp {
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      @media (prefers-reduced-motion: reduce) {
        .intro-avatar, .intro-title, .intro-subtitle, .intro-socials, .intro-card {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }
      }

      .link-card {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        transform: perspective(700px) rotateX(0deg) translateY(0) scale(1);
        transition: transform .4s cubic-bezier(.22,1,.36,1), box-shadow .4s ease;
      }
      .link-card:hover {
        transform: perspective(700px) rotateX(3deg) translateY(-5px) scale(1.02);
      }
      .link-card:active {
        transform: perspective(700px) rotateX(1deg) translateY(-1px) scale(.98);
        transition-duration: .12s;
      }

      .card-particles {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: visible;
      }

      .card-particles svg {
        position: absolute;
        opacity: 0;
        will-change: transform, opacity;
        filter: drop-shadow(0 3px 6px rgba(0,0,0,.25));
      }

      .link-card:hover .card-particles svg {
        animation: particleFloat 1.3s ease-out forwards;
      }
      .link-card:hover .card-particles svg:nth-child(1) { animation-delay: 0s; }
      .link-card:hover .card-particles svg:nth-child(2) { animation-delay: .1s; }
      .link-card:hover .card-particles svg:nth-child(3) { animation-delay: .22s; }
      .link-card:hover .card-particles svg:nth-child(4) { animation-delay: .34s; }
      .link-card:hover .card-particles svg:nth-child(5) { animation-delay: .46s; }

      @keyframes particleFloat {
        0% { opacity: 0; transform: translateY(8px) scale(.4) rotate(-8deg); }
        18% { opacity: 1; transform: translateY(-8px) scale(1) rotate(3deg); }
        100% { opacity: 0; transform: translateY(-52px) scale(.8) rotate(14deg); }
      }

      .p-a { left: 10%; top: 50%; }
      .p-b { left: 30%; top: 35%; }
      .p-c { left: 50%; top: 55%; }
      .p-d { left: 70%; top: 35%; }
      .p-e { left: 88%; top: 50%; }

      .card-content { position: relative; z-index: 2; }

      .icon-breathe { transition: transform .35s ease; }
      .link-card:hover .icon-breathe { transform: scale(1.12) rotate(-4deg); }

      .ripple::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        border-radius: inherit;
        background: radial-gradient(circle at var(--rx,50%) var(--ry,50%), rgba(255,255,255,.5) 0%, rgba(255,255,255,0) 60%);
        opacity: 0;
        pointer-events: none;
      }
      .ripple.is-clicked::after {
        opacity: 1;
        animation: rippleFade .55s ease-out forwards;
      }
      @keyframes rippleFade { to { opacity: 0; } }

      .theme-github {
        background: linear-gradient(135deg, #0d1117, #161b22);
        border-color: #30363d !important;
      }
      .theme-github .card-content { color: #c9d1d9; }
      .theme-github:hover { border-color: #3fb950 !important; box-shadow: 0 10px 30px -10px rgba(63,185,80,.35); }
      .theme-github .gh-scan {
        position: absolute; inset: 0; z-index: 1; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(63,185,80,.08), transparent);
        transform: translateY(-100%);
      }
      .theme-github:hover .gh-scan { animation: ghScan 1.1s ease-out; }
      @keyframes ghScan { to { transform: translateY(100%); } }

      .theme-linkedin { background: linear-gradient(120deg, #0A66C2, #2d8eff); }
      .li-net {
        position: absolute; inset: 0; z-index: 1; pointer-events: none;
        opacity: 0;
      }
      .link-card:hover .li-net { opacity: 1; }
      .li-net circle { opacity: 0; }
      .li-net line {
        stroke-dasharray: 60;
        stroke-dashoffset: 60;
      }
      .link-card:hover .li-net line { animation: liDraw .8s ease-out forwards; }
      .link-card:hover .li-net circle { animation: liDot .4s ease-out forwards; }
      .link-card:hover .li-net line:nth-child(2) { animation-delay: .1s; }
      .link-card:hover .li-net line:nth-child(3) { animation-delay: .2s; }
      .link-card:hover .li-net circle:nth-child(4) { animation-delay: .35s; }
      .link-card:hover .li-net circle:nth-child(5) { animation-delay: .45s; }
      .link-card:hover .li-net circle:nth-child(6) { animation-delay: .55s; }
      @keyframes liDraw { to { stroke-dashoffset: 0; } }
      @keyframes liDot { to { opacity: .8; } }

    
      .theme-instagram {
        position: relative;
        background: #fff;
      }
      .dark .theme-instagram { background: #161616; }
      .theme-instagram::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        border-radius: inherit;
        padding: 2px;
        background: conic-gradient(from 0deg, #FEDA75, #FA7E1E, #D62976, #962FBF, #4F5BD5, #FEDA75);
        opacity: 0;
        transition: opacity .35s ease;
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
      }
      .link-card.theme-instagram:hover::before {
        opacity: 1;
        animation: igSpin 2.5s linear infinite;
      }
      @keyframes igSpin { to { transform: rotate(360deg); } }
      .theme-instagram .ig-flash {
        position: absolute; inset: 0; z-index: 1; pointer-events: none;
        background: radial-gradient(circle at 85% 20%, rgba(255,255,255,.5), transparent 45%);
        opacity: 0;
      }
      .link-card:hover .ig-flash { animation: igFlashPulse 1.4s ease-in-out; }
      @keyframes igFlashPulse { 0%, 100% { opacity: 0; } 50% { opacity: 1; } }

    
      .theme-codeforces {
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        border-color: #2a2a4a !important;
      }
      .theme-codeforces:hover { border-color: #FF7E00 !important; box-shadow: 0 10px 30px -10px rgba(255,126,0,.4); }
      .cf-chart {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 38%;
        z-index: 1;
        pointer-events: none;
        opacity: .55;
      }
      .cf-chart path {
        stroke-dasharray: 300;
        stroke-dashoffset: 300;
      }
      .link-card:hover .cf-chart path { animation: cfRise 1s ease-out forwards; }
      @keyframes cfRise { to { stroke-dashoffset: 0; } }

      .blog-underline {
        position: absolute;
        bottom: 14px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #FF7E00, #FFC900);
        border-radius: 2px;
        z-index: 1;
        transition: width .4s ease;
      }
      .link-card:hover .blog-underline { width: 46%; }

  
      @media (max-width: 380px) {
        .card-particles svg:nth-child(4),
        .card-particles svg:nth-child(5) { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        .link-card, .link-card:hover, .icon-breathe, .link-card:hover .icon-breathe,
        .card-particles svg, .gh-scan, .li-net, .theme-instagram::before, .ig-flash,
        .cf-chart path, .blog-underline {
          animation: none !important;
          transition: none !important;
        }
      }

      .status-ring {
        position: absolute; inset: -4px; border-radius: 9999px;
        border: 2px solid #34D399; opacity: 0;
        animation: statusPulse 2.4s ease-out infinite;
      }
      @keyframes statusPulse {
        0% { transform: scale(.85); opacity: .8; }
        70% { opacity: 0; }
        100% { transform: scale(1.35); opacity: 0; }
      }
      .status-dot {
        position: absolute; bottom: -2px; right: -2px;
        width: 14px; height: 14px; border-radius: 9999px;
        background: #34D399; border: 2.5px solid white;
      }
      .dark .status-dot { border-color: #0b1220; }

      .signal-badge {
        position: absolute; top: -10px; right: 16px; z-index: 3;
        font-size: .65rem; font-weight: 700; letter-spacing: .02em;
        padding: 3px 9px; border-radius: 9999px; white-space: nowrap;
        box-shadow: 0 4px 10px rgba(0,0,0,.2);
        animation: badgeBob 2.6s ease-in-out infinite;
      }
      @keyframes badgeBob {
        0%, 100% { transform: translateY(0) rotate(-2deg); }
        50% { transform: translateY(-3px) rotate(1deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        .status-ring, .signal-badge { animation: none !important; }
      }

      .confetti-piece {
        position: fixed; top: 0; left: 0; width: 7px; height: 7px;
        border-radius: 2px; pointer-events: none; z-index: 60; opacity: 0;
      }
    </style>

</head>

<body class="bg-slate-50 dark:bg-bgdark text-subgdark dark:text-slate-100 min-h-screen grid-background relative">

  <div class="ambient-bg" aria-hidden="true">
    <span class="ambient-shape ambient-1"></span>
    <span class="ambient-shape ambient-2"></span>
    <span class="ambient-shape ambient-3"></span>
    <span class="ambient-shape ambient-4"></span>
    <span class="ambient-shape ambient-5"></span>

    <svg class="ambient-particle" style="left:8%; width:14px; animation-duration:16s; animation-delay:0s;" viewBox="0 0 24 24" fill="none" stroke="#FF7E00" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2L4 7v10l8 5 8-5V7l-8-5z"/></svg>
