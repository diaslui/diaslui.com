    <svg class="ambient-particle" style="left:74%; width:14px; animation-duration:22s; animation-delay:8s;" viewBox="0 0 24 24" fill="none" stroke="#FFC900" stroke-width="2"><path stroke-linecap="round" d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/></svg>
    <svg class="ambient-particle" style="left:88%; width:10px; animation-duration:17s; animation-delay:4s;" viewBox="0 0 24 24" fill="#FF7E00"><circle cx="12" cy="12" r="10"/></svg>
    <svg class="ambient-particle" style="left:15%; width:12px; animation-duration:19s; animation-delay:10s;" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/></svg>
    <svg class="ambient-particle" style="left:65%; width:13px; animation-duration:21s; animation-delay:12s;" viewBox="0 0 24 24" fill="#E1306C"><polygon points="12,2 22,20 2,20"/></svg>
  </div>

  <div class="w-full mt-5 px-2 relative z-10">

    <a href="/" class="flex items-center gap-2 sm:gap-3 group">
      <img src="/assets/img/full-diaslui.png" alt="Diaslui Logo" class=" mx-4 w-10 h-10 sm:w-10 sm:h-10"></img>

    </a>
    <button onclick="toggleTheme()"
      class="fixed top-6 right-6 p-3 rounded-full bg-white/80 dark:bg-subgdark/80 backdrop-blur-lg hover:bg-white dark:hover:bg-slate-800 shadow-lg z-50 transition-all hover:scale-110"
      aria-label="Toggle theme">
      <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
      </svg>
      <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
        </path>
      </svg>
    </button>
  </div>


  <div class="w-full mt-5 max-w-2xl mx-auto relative z-10">

    <div class="text-center mb-8 sm:mb-12">

      <!-- Avatar com anel de status "online" -->
      <div class="intro-avatar relative w-20 h-20 mx-auto mb-4">
        <img src="/assets/img/full-diaslui.png" alt="Pedro Luis"
          class="relative w-20 h-20 rounded-full object-cover">
        <span class="status-dot" title="Disponível"></span>
      </div>

