<!DOCTYPE html>
<html lang="en" class="text-base">
  <%- include('partials/head', { title: title, description: description }) %>
        <script src="/assets/scripts/global.js"></script>

  <body
    class="flex h-screen flex-col bg-zinc-50 text-zinc-950 dark:bg-zinc-900 dark:text-zinc-50"
  >
    <%- include('partials/header') %>
    <main class="flex-1">
      <div class="container mx-auto mt-10 max-w-5xl px-4">
        <div class="mb-10 text-center">
          <h1 class="mb-4 text-4xl font-extrabold tracking-tight sm:text-5xl">Solved <span class="text-amber-600 dark:text-amber-500">Problems</span></h1>
          <p class="mx-auto max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
            Browse and search through my solved challenges from Codeforces. 
            All algorithmic approaches and answers are available here.
          </p>
        </div>
        
        <div class="relative mb-12 max-w-2xl mx-auto">
          <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
            <svg aria-hidden="true" class="w-5 h-5 text-zinc-500 dark:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <input
            type="text"
            id="search-input"
            placeholder="Search problems by name or ID (e.g., 116A)..."
            class="block w-full rounded-2xl border border-zinc-300 bg-white p-4 pl-12 text-sm text-zinc-900 shadow-sm transition focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 dark:border-zinc-700 dark:bg-zinc-900/50 dark:text-white dark:placeholder-zinc-400 dark:focus:border-amber-500 dark:focus:ring-amber-500"
          />
        </div>

        <div id="problems-container" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        </div>

        <div id="loading" class="mt-8 text-center">
          <p class="text-lg">Loading problems...</p>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
    <script src="assets/scripts/problems.js"></script>
  </body>
</html>
