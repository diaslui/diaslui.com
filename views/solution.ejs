<!DOCTYPE html>
<html lang="en" class="text-base">
  <title><%= title %></title>
  <%- include('partials/head', { title: title, description: description }) %>
      <script src="/assets/scripts/global.js"></script>

  <body
    class="flex h-screen flex-col bg-zinc-50 text-zinc-950 dark:bg-zinc-900 dark:text-zinc-50"
  >
    <%- include('partials/header') %>
    <main class="flex-1">
      <div class="container mx-auto mt-10 max-w-4xl px-4 pb-12">
        
        <div class="mb-8">
          <a href="/problems" class="inline-flex items-center text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors dark:text-zinc-400 dark:hover:text-zinc-100">
            <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Problems
          </a>
        </div>

        <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-4xl">
              <%= solution.name %>
            </h1>
            <p class="mt-2 text-zinc-600 dark:text-zinc-400">
                C++ implementation &copy; 2026 Pedro Luis D. 
            </p>
          </div>
          <a href="<%= solution.problemUrl %>" target="_blank" rel="noopener noreferrer" class="mt-4 gap-2 inline-flex items-center justify-center rounded-lg border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-900 shadow-sm hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-50 dark:hover:bg-zinc-700/80 sm:mt-0 transition-colors">
            View on 
                        <img src="/assets/img/codeforces-logo.png" alt="Codeforces Logo" class="mr-2 h-auto w-24">

          </a>
        </div>

        <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
          <div class="flex items-center justify-between border-b border-zinc-200 bg-zinc-50 px-4 py-3 dark:border-zinc-800 dark:bg-zinc-900/50">
            <div class="flex space-x-2">
              <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
              <div class="h-3 w-3 rounded-full bg-amber-400"></div>
              <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
            </div>
            <div class="text-xs font-medium text-zinc-500 font-mono"><%= solution.name %>.cpp</div>
            <div class="w-12"></div> 
          </div>
          <div class="prose prose-zinc max-w-none dark:prose-invert ">
            <pre class="m-0 !rounded-none !bg-transparent p-4 text-sm leading-relaxed overflow-x-auto"><code class="language-cpp"><%- solution.content %></code></pre>
          </div>
        </div>
        
      </div>
    </main>
    <%- include('partials/footer') %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
  </body>
</html>
